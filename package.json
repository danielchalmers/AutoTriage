{
  "name": "autotriage",
  "version": "0.1.0",
  "description": "AI triage for GitHub issues & PRs: reads context, drafts the next move, and applies it with your project prompt.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "npm run typecheck && npm run clean && ncc build src/index.ts -o dist --minify --source-map --license licenses.txt && npm run copy-assets",
    "copy-assets": "node -e \"require('fs').cpSync('examples/AutoTriage.prompt', 'dist/AutoTriage.prompt')\"",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true, force:true})\"",
    "typecheck": "tsc --noEmit",
    "dev": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "github-actions",
    "triage",
    "issues",
    "pull-requests",
    "ai"
  ],
  "author": "Daniel Chalmers",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "action.yml",
    "README.md",
    "dist/"
  ],
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@google/genai": "1.21.0",
    "chalk": "^5.6.2"
  }
}
